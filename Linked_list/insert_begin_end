class Node:
    def __init__(self,data=None,next=None):
        self.data=data
        self.next=next
class linked_list:
    def __init__(self):
        self.head=None
    def insert_at_begin(self,data):
        
        node=Node(data,self.head)
        self.head=node
        
    def print(self):
        if self.head is None:
            print("Linked list is empty")
            return
        lst=self.head
        
        while lst:
            print(lst.data,"-->",end="")
            lst=lst.next
        
    def insert_at_end(self,data):
        if self.head is None:
            node=Node(data,None)
            self.head=node
            return
        lst=self.head
        while lst.next:
            lst=lst.next
        lst.next=Node(data,None)
    def insert_list(self,lst):
        for data in lst:
             self.insert_at_end(data)
ll=linked_list()
ll.insert_at_begin(12)
ll.insert_at_begin(23)
b=["titus","kesya","solomon","baby","jacob"]
ll.insert_list(b)
ll.insert_at_end(243)
ll.print()
