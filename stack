#stack follows Last in First Out(LIFO) Principle

#program

from collections import deque
stack=deque
class Stack:
    def __init__(self):
        self.stack = []

    def push(self, data):
        self.stack.append(data)

    def pop(self):
        if len(self.stack) == 0:
            return "Stack Underflow"
        return self.stack.pop()

    def peek(self):
        if len(self.stack) == 0:
            return "Stack is empty"
        return self.stack[-1]

    def is_empty(self):
        return len(self.stack) == 0

    def size(self):
        return len(self.stack)

    def display(self):
        print(self.stack)


s = Stack()

s.push(10)
s.push(20)
s.push(30)

s.display()

print("Top:", s.peek())

print("Removed:", s.pop())

s.display()

print("Size:", s.size())

print("Empty:", s.is_empty())
